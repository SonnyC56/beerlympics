# ── Convex ────────────────────────────────────────────────────────────────
# Created automatically when you run `npx convex dev` for the first time.
# Copy the deployment URL it prints into NEXT_PUBLIC_CONVEX_URL.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex deploy key (used by Vercel for production deploys). Get it from the
# Convex dashboard → Settings → Deploy keys. Do NOT commit the real value.
CONVEX_DEPLOY_KEY=

# ── App ───────────────────────────────────────────────────────────────────
# Public base URL of the deployed app — used to build shareable invite links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Resend) ─────────────────────────────────────────────────────────
# These are set on the CONVEX deployment (emails send from a Convex action), not
# on Vercel. Set them with:  npx convex env set RESEND_API_KEY re_xxx
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
# The "from" address. Must be a verified domain in Resend (or use the sandbox
# onboarding@resend.dev for testing). e.g. "Beerlympics <invites@yourdomain.com>"
RESEND_FROM="Beerlympics <onboarding@resend.dev>"
# Reply-to (optional) — where guest replies land, e.g. your personal email.
RESEND_REPLY_TO=
